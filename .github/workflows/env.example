# Copy these as GitHub repository Variables (Settings → Secrets and variables → Actions → Variables).
# Do not commit real .env files.

# --- Web (Playwright) ---
WEB_UAT_BASE_URL=https://web.cricket-australia.dev.pulselive.com
WEB_PROD_BASE_URL=https://www.cricket.com.au
WEB_MATCH_PATH_PREFIX=/matches/CA:
PLAYWRIGHT_WORKERS=2

# --- Fixtures / ticker ---
MOBILE_FIXTURES_URL_PROD=https://apiv2.cricket.com.au/web/matchticker/fixtures?Region=AU&format=json
MOBILE_FIXTURES_URL_UAT=https://apiv2.cricket.com.au/web/matchticker/fixtures?Region=AU&format=json
MOBILE_FALLBACK_MATCH_ID=40266

# --- Mobile config spinner ---
MOBILE_CONFIG_PROD_HOST_TEXT=apiv2.cricket.com.au/mobile
MOBILE_CONFIG_UAT_HOST_SUBSTRING=fans-uat-api.cadigitaltechnology.com
MOBILE_APP_PACKAGE=au.com.cricket

# --- APK release (split bundle for x86_64 emulator) ---
RELEASE_REPO=ijuzv/apiCompareGithubRunner
RELEASE_TAG=v1
