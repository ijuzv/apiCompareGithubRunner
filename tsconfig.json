{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "reports-dashboard/**/*.ts",
    "master-scheduler/**/*.ts",
    "common-utils/**/*.ts"
  ]
}
