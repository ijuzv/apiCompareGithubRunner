# Copy to ".env" in this folder (playwright-api-compare) or set the same keys in the repo-root .env.
# Package-local .env overrides repo-root .env when both exist.

# --- Web match URLs (UAT vs prod) ---
WEB_UAT_BASE_URL=https://web.cricket-australia.dev.pulselive.com
WEB_PROD_BASE_URL=https://www.cricket.com.au
# Path before ticker Id from fixtures, e.g. /matches/CA:40266
WEB_MATCH_PATH_PREFIX=/matches/CA:
# Saved layout: screenshots/{Home-vs-Away_id###}/{run-timestamp}/v2-{tab}.png (prod) and v3-{tab}.png (UAT).

# --- Which match(es) to open (FixtureFetcher / ticker) ---
# Optional: override default CA ticker JSON URL
# MOBILE_FIXTURES_URL_PROD=https://apiv2.cricket.com.au/web/matchticker/fixtures?Region=AU&format=json
# MOBILE_FIXTURES_URL_UAT=https://apiv2.cricket.com.au/web/matchticker/fixtures?Region=AU&format=json
# When ticker has no live / in-window match, use this numeric Id (root Fixtures[].Id)
MOBILE_FALLBACK_MATCH_ID=40266
# Set to 1 to only pick IsLive fixtures (otherwise in-window or fallback applies)
# MOBILE_FIXTURES_LIVE_ONLY=0

# --- Playwright run ---
# HEADLESS=false runs headed
HEADLESS=true
WORKERS=2
# Optional legacy / other flows
# SCREENSHOT_INTERVAL=300000
# DEVICE=Desktop Chrome

# --- Optional: multi-browser (default is Chromium only) ---
# PLAYWRIGHT_ALL_BROWSERS=1

# --- Optional: legacy v1/v2 app URLs (not used by current web match screenshot spec) ---
# BASE_URL_V1=http://localhost:3000/v1
# API_URL_V1=http://localhost:4000/v1
# BASE_URL_V2=http://localhost:3000/v2
# API_URL_V2=http://localhost:4000/v2
