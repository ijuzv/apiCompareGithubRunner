# Copy to ".env" in this folder or export variables in your shell before running tests.
# This project does not load .env automatically unless you add dotenv or your runner injects it.

# --- Android / Appium (system; set in OS env or IDE so Appium and adb see them) ---
# ANDROID_HOME=C:\Users\You\AppData\Local\Android\Sdk
# ANDROID_SDK_ROOT=%ANDROID_HOME%
# PATH must include %ANDROID_HOME%\platform-tools

# --- Installed app id (must match the APK; wdio, deep links, adb install verify) ---
# MOBILE_APP_PACKAGE=au.com.cricket

# --- Deep links (must match merged manifest / App Links) ---
# MOBILE_DEEP_LINK_CONFIG=cricketapp://config
# HTTPS match `-d` URI (append root ticker Id). Default in code: https://www.cricket.com.au/matches/CA:
# MOBILE_DEEP_LINK_MATCH_BASE=https://www.cricket.com.au/matches/CA:
# adb `am start … -n` component (default au.com.cricket/.ui.SplashActivity):
# MOBILE_ADB_VIEW_COMPONENT=au.com.cricket/.ui.SplashActivity
# Serials for match adb open (space or comma); default emulator-5554 emulator-5556
# MOBILE_ADB_MATCH_DEVICE_SERIALS=emulator-5554,emulator-5556

# --- Live match IDs (FixtureFetcher; prod and UAT both default to apiv2 public ticker) ---
# MOBILE_FIXTURES_URL_PROD=https://apiv2.cricket.com.au/web/matchticker/fixtures?Region=AU&format=json
# MOBILE_FIXTURES_URL_UAT=https://apiv2.cricket.com.au/web/matchticker/fixtures?Region=AU&format=json
# Set to 1 to use only IsLive fixtures (no time-window fallback when none are live).
# MOBILE_FIXTURES_LIVE_ONLY=0
# Fallback match id from ticker root Fixtures[].Id when no live / no in-window match (default 40266).
# MOBILE_FALLBACK_MATCH_ID=40266

# --- Test flow ---
# Optional: force prod/uat behaviour regardless of device serial (cannot use custom WDIO caps)
# MOBILE_FORCE_ENV=prod
# Set to 1 to use legacy cricketapp://config + accessibility-id config (v1/v2) instead of Spinner env UI
# MOBILE_USE_LEGACY_CONFIG=0

# --- CA pre-config spinner (apiAzureEndPoints) — full row text prod; substring for UAT last row ---
# MOBILE_CONFIG_PROD_HOST_TEXT=apiv2.cricket.com.au/mobile
# MOBILE_CONFIG_UAT_HOST_SUBSTRING=fans-uat-api.cadigitaltechnology.com
